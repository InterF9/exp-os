alias currentPID R0;
currentPID = [SYSTEM_STATUS_TABLE+1];

alias process_table_entry R1;
process_table_entry = PROCESS_TABLE + 16*currentPID;

[process_table_entry + 4] = TERMINATED;
alias i R2;
i=1;
while ((i<16) && ([PROCESS_TABLE + 16*i + 4] == TERMINATED)) do
    i = i+1;
endwhile;

if (i>=16) then
    halt;
endif;

call MOD_5;
